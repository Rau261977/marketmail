// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  settings  TenantEmailSetting?
  users     User[]
  leads     Lead[]
  templates EmailTemplate[]
  campaigns EmailCampaign[]
  sequences EmailSequence[]
  queue     EmailQueue[]
  logs      EmailLog[]

  @@map("tenants")
}

model TenantEmailSetting {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @unique @map("tenant_id") @db.Uuid
  fromEmail             String   @map("from_email")
  fromName              String   @map("from_name")
  replyTo               String?  @map("reply_to")
  brandingLogoUrl       String?  @map("branding_logo_url")
  brandingPrimaryColor  String   @default("#000000") @map("branding_primary_color")
  resendApiKey          String?  @map("resend_api_key")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_email_settings")
}

model Lead {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  email          String
  name           String?
  metadata       Json?     @default("{}")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  queue  EmailQueue[]
  logs   EmailLog[]

  @@unique([tenantId, email])
  @@map("leads")
}

model EmailTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  slug        String
  subject     String
  contentJson Json?    @map("content_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaigns     EmailCampaign[]
  sequenceSteps SequenceStep[]
  queue         EmailQueue[]
  logs          EmailLog[]

  @@unique([tenantId, slug])
  @@map("email_templates")
}

model EmailCampaign {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  templateId   String    @map("template_id") @db.Uuid
  name         String
  segmentQuery Json?     @map("segment_query")
  scheduledAt  DateTime? @map("scheduled_at")
  status       String    @default("draft")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template  EmailTemplate @relation(fields: [templateId], references: [id])
  queue     EmailQueue[]

  @@map("email_campaigns")
}

model EmailSequence {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps  SequenceStep[]

  @@map("email_sequences")
}

model SequenceStep {
  id         String   @id @default(uuid()) @db.Uuid
  sequenceId String   @map("sequence_id") @db.Uuid
  templateId String   @map("template_id") @db.Uuid
  delayDays  Int      @default(0) @map("delay_days")
  stepOrder  Int      @map("step_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  template   EmailTemplate @relation(fields: [templateId], references: [id])

  @@unique([sequenceId, stepOrder])
  @@map("sequence_steps")
}

model EmailQueue {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  leadId        String    @map("lead_id") @db.Uuid
  templateId    String?   @map("template_id") @db.Uuid
  campaignId    String?   @map("campaign_id") @db.Uuid
  variablesJson Json?     @default("{}") @map("variables_json")
  status        String    @default("pending")
  retryCount    Int       @default(0) @map("retry_count")
  errorLog      String?   @map("error_log")
  scheduledAt   DateTime  @default(now()) @map("scheduled_at")
  sentAt        DateTime? @map("sent_at")
  resendId      String?   @map("resend_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template  EmailTemplate? @relation(fields: [templateId], references: [id])
  campaign  EmailCampaign? @relation(fields: [campaignId], references: [id])

  @@map("email_queue")
}

model EmailLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  leadId     String   @map("lead_id") @db.Uuid
  templateId String?  @map("template_id") @db.Uuid
  resendId   String?  @unique @map("resend_id")
  status     String
  openedAt   DateTime? @map("opened_at")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead     Lead           @relation(fields: [leadId], references: [id])
  template EmailTemplate? @relation(fields: [templateId], references: [id])

  @@map("email_logs")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  password  String   @default("password123") // Temporary mock password
  role      String   @default("ADMIN")
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}
